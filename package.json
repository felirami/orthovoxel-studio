{
  "name": "orthovoxel-studio",
  "version": "0.1.0",
  "description": "Clean-room orthographic pixel-to-voxel desktop art tool.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "desktop": "concurrently -k \"npm run dev\" \"wait-on tcp:127.0.0.1:5173 && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc --noEmit --pretty false && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "studio.orthovoxel.app",
    "productName": "OrthoVoxel Studio",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}
